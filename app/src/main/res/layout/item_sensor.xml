<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:layout_marginBottom="8dp"
    android:background="#2ED59E"
    android:padding="8dp">

    <!-- CÍRCULO SENSOR -->
    <View
        android:id="@+id/circleSensor"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/circle_green"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- NOMBRE SENSOR -->
    <TextView
        android:id="@+id/txtNombreSensor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nom_sensor"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/circleSensor"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/txtInfoSensor"
        android:layout_marginStart="12dp"/>

    <!-- INFO SENSOR -->
    <TextView
        android:id="@+id/txtInfoSensor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Info sensor"
        android:textColor="@android:color/black"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
