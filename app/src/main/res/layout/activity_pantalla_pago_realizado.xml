<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDEDED">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarPagoRealizado"
        android:layout_width="0dp"
        android:layout_height="155dp"
        android:background="#294FA3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="16dp"
                android:src="@drawable/iconomen"
                app:tint="@android:color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintVertical_bias="0.75"/>

            <ImageView
                android:layout_width="140dp"
                android:layout_height="40dp"
                android:scaleType="fitCenter"
                android:src="@drawable/pagoslogo"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.415"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.773" />

            <ImageView
                android:id="@+id/btnCarrito"
                android:layout_width="80dp"
                android:layout_height="70dp"
                android:layout_marginEnd="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/logo3"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.811" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.appcompat.widget.Toolbar>

    <include
        android:id="@+id/filtroInclude"
        layout="@layout/filtro_recyclerview"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbarPagoRealizado"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:id="@+id/scrollFactura"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarPagoRealizado"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layoutFactura"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:src="@drawable/pagorealizado"
                android:scaleType="fitCenter"/>

            <ImageView
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:src="@drawable/botoncomprapago"
                android:scaleType="fitCenter"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LOCAL MARKET"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#294FA3"
                        android:layout_gravity="center"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FACTURA"
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:layout_gravity="center"
                        android:layout_marginBottom="12dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/txtFacturaPedidoId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pedido: #---"
                        android:textSize="12sp"
                        android:textColor="#444444"/>

                    <TextView
                        android:id="@+id/txtFacturaFecha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha: ---"
                        android:textSize="12sp"
                        android:textColor="#444444"
                        android:layout_marginBottom="12dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DATOS DEL COMPRADOR"
                        android:textStyle="bold"
                        android:textColor="#294FA3"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/txtFacturaNombre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre: ---"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/txtFacturaEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email: ---"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/txtFacturaTelefono"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Teléfono: ---"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/txtFacturaDireccion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dirección: ---"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRODUCTOS"
                        android:textStyle="bold"
                        android:textColor="#294FA3"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/txtFacturaProductos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="---"
                        android:textSize="12sp"
                        android:textColor="#444444"
                        android:layout_marginBottom="12dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RESUMEN DEL PEDIDO"
                        android:textStyle="bold"
                        android:textColor="#294FA3"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Subtotal productos" android:textSize="12sp"/>
                        <TextView android:id="@+id/txtFacturaSubtotal"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.00 €" android:textSize="12sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Gastos de envío" android:textSize="12sp"/>
                        <TextView android:id="@+id/txtFacturaEnvio"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.00 €" android:textSize="12sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="IVA (6%)" android:textSize="12sp"/>
                        <TextView android:id="@+id/txtFacturaIva"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.00 €" android:textSize="12sp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#294FA3"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="TOTAL A PAGAR"
                            android:textStyle="bold" android:textColor="#294FA3" android:textSize="14sp"/>
                        <TextView android:id="@+id/txtFacturaTotal"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.00 €" android:textStyle="bold"
                            android:textColor="#294FA3" android:textSize="14sp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnDescargarPDF"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="⬇ Descargar factura PDF"
                android:textColor="@android:color/white"
                android:backgroundTint="#0B4DB8"/>


        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#294FA3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnFavorito"
            android:layout_width="wrap_content"
            android:layout_height="54dp"
            android:layout_margin="24dp"
            android:src="@drawable/favori"
            app:tint="@android:color/white" />

        <ImageView
            android:id="@+id/btnInvernadero"
            android:layout_width="94dp"
            android:layout_height="77dp"
            android:layout_margin="24dp"
            android:src="@drawable/sensor" />

        <ImageView
            android:id="@+id/btnAjuste"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:layout_margin="24dp"
            android:src="@drawable/botones"
            app:tint="@android:color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>