<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- IMAGEN PRODUCTO -->
        <ImageView
            android:id="@+id/imgProducto"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:background="#DDDDDD"
            android:scaleType="centerCrop"/>

        <!-- NOMBRE -->
        <TextView
            android:id="@+id/txtNombreProducto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Nombre producto"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <!-- CATEGORIA -->
        <TextView
            android:id="@+id/txtCategoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Categoría"
            android:textColor="#666666"/>

        <!-- PRECIO -->
        <TextView
            android:id="@+id/txtPrecio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2.5 €"
            android:textColor="#0B4DB8"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <!-- DESCRIPCIÓN -->
        <TextView
            android:id="@+id/txtDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detalle del producto"
            android:layout_marginTop="8dp"/>

        <!-- CANTIDAD -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnMenos"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                android:backgroundTint="#294FA3"
                android:tint="@android:color/white"/>

            <TextView
                android:id="@+id/txtCantidad"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1"
                android:textSize="16sp"
                android:layout_marginHorizontal="8dp"/>

            <ImageButton
                android:id="@+id/btnMas"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_next"
                android:backgroundTint="#294FA3"
                android:tint="@android:color/white"/>
        </LinearLayout>

        <!-- BOTÓN COMPRAR -->
        <Button
            android:id="@+id/btnComprar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="Comprar"
            android:backgroundTint="#294FA3"
            android:textColor="@android:color/white"/>

        <!-- COMENTARIO -->
        <EditText
            android:id="@+id/edtComentario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Escribe un comentario"
            android:layout_marginTop="16dp"/>

        <Button
            android:id="@+id/btnComentar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comentar"
            android:layout_marginTop="8dp"
            android:backgroundTint="#6A4FB6"
            android:textColor="@android:color/white"/>

        <!-- LISTA COMENTARIOS -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerComentarios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
