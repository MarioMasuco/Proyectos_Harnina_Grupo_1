<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Fila 1: Nombre tienda -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre tienda:"
            android:textSize="20sp"
            android:layout_gravity="center_vertical" />

        <EditText
            android:id="@+id/etCorreo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:background="@drawable/bocadillo_dialogo"
            android:hint="   Nombre"
            android:inputType="textPersonName" />
    </LinearLayout>

    <!-- Fila 2: Usuario propietario -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usu propietario"
            android:textSize="20sp"
            android:layout_gravity="center_vertical" />

        <EditText
            android:id="@+id/etCorreo3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:background="@drawable/bocadillo_dialogo"
            android:hint="   Nombre Usu"
            android:inputType="textPersonName" />
    </LinearLayout>

    <!-- Fila 3: Descripción -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descripcion:"
            android:textSize="20sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etCorreo2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="120dp"
            android:gravity="top"
            android:background="@drawable/bocadillo_dialogo"
            android:inputType="textMultiLine"
            android:hint="   Introduce una descripción..." />
    </LinearLayout>

    <!-- NUEVA FILA 4: Categorías (respetando tu estilo) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categorías:"
            android:textSize="20sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etCategorias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bocadillo_dialogo"
            android:hint="   Ej: Herramientas, Pintura, Electricidad..."
            android:inputType="textCapWords" />
    </LinearLayout>

    <!-- Fila 5: Spinner y Botón (renombrada para claridad) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Spinner
            android:id="@+id/spinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/inicio7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="@drawable/botoncolorpre_crear"
            android:clickable="true"
            android:focusable="true"
            android:stateListAnimator="@null"
            android:text="Crear"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp" />
    </LinearLayout>

</LinearLayout>