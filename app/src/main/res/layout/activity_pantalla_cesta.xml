<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDEDED">

    <!-- ================= TOOLBAR ================= -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarCesta"
        android:layout_width="0dp"
        android:layout_height="155dp"
        android:background="#294FA3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="39dp"
                android:layout_height="35dp"
                android:layout_marginStart="16dp"
                android:scaleType="centerInside"
                android:src="@drawable/iconomen"
                app:tint="@android:color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintVertical_bias="0.78"/>

            <ImageView
                android:layout_width="150dp"
                android:layout_height="40dp"
                android:scaleType="fitCenter"
                android:src="@drawable/cesta"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintVertical_bias="0.78"/>

            <ImageView
                android:id="@+id/btnCarrito"
                android:layout_width="85dp"
                android:layout_height="70dp"
                android:layout_marginEnd="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/logo3"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.9" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- ================= FILTRO ================= -->
    <include
        android:id="@+id/filtroInclude"
        layout="@layout/filtro_recyclerview"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbarCesta"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= LISTA CESTA ================= -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCesta"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarCesta"
        app:layout_constraintBottom_toTopOf="@id/layoutTotal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= TOTAL + COMPRAR ================= -->
    <LinearLayout
        android:id="@+id/layoutTotal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total a pagar: 0 €"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"/>

        <Button
            android:id="@+id/btnComprar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Comprar"
            android:textColor="@android:color/white"
            android:backgroundTint="#294FA3"/>
    </LinearLayout>

    <!-- ================= BOTTOM NAV ================= -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#294FA3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnFavorito"
            android:layout_width="wrap_content"
            android:layout_height="54dp"
            android:layout_margin="24dp"
            android:src="@drawable/favori"
            app:tint="@android:color/white" />

        <ImageView
            android:id="@+id/btnInvernadero"
            android:layout_width="94dp"
            android:layout_height="77dp"
            android:layout_margin="24dp"
            android:src="@drawable/sensor" />

        <ImageView
            android:id="@+id/btnAjuste"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:layout_margin="24dp"
            android:src="@drawable/botones"
            app:tint="@android:color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
